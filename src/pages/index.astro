    focus: "Where were you born? & Can I take a message? (Biographical info; years; school days; telephone calls; invitations; Grammar Plus)",
    songs: [
      { title: "We're Going on a Bear Hunt - Song", url: "https://www.youtube.com/watch?v=WzIcu6tbEko", type: "song" },
      { title: "Goodbye Song - Super Simple", url: "https://www.youtube.com/watch?v=48356-H1pWY", type: "song" }
    ],
    sessions: [
      { number: 1, sb: "Pages 100-102: Unit 15. Biographical information; years. Statements with the past of be (was, were)", wb: "Pages 85-86 (exercises 1-2)", extra: "Asking for and giving information about date and place of birth" },
      { number: 2, sb: "Pages 103-105: Unit 15. School days. Questions with the past of be; Wh-questions with did. GRAMMAR PLUS (Pages 132-139)", wb: "Pages 87-90 (exercises 3-5)", extra: "Describing school experiences and childhood memories" },
      { number: 3, sb: "Pages 106-108: Unit 16. Locations; telephone calls. Prepositional phrases; subject and object pronouns", wb: "Pages 91-92 (exercises 1-3)", extra: "Describing people's locations; making phone calls & messages" },
      { number: 4, sb: "Pages 109-111: Unit 16. Invitations with Do you want to...? and Would you like to...?; verb + to. GRAMMAR PLUS (Pages 140-150)", wb: "Pages 93-96 (exercises 4-6) + Grammar Plus review", extra: "Making, accepting, and declining invitations; making excuses; final celebration" }
    ]
  }
];

// Available avatars for member creation
const AVATARS = ['👧', '👦', '👩', '👨', '🦁', '🐼', '🦄', '🚀', '🎨', '🎮', '🍕', '🦊', '🐸'];
---

<Layout title="English Adventure • Family Agenda">
  <!-- Container -->
  <main class="max-w-4xl mx-auto w-full px-4 py-8 flex-grow">
    
    <!-- Hero Header -->
    <header class="relative rounded-3xl overflow-hidden bg-slate-900 shadow-xl mb-8 border border-slate-800">
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-900/40 to-transparent z-10"></div>
      <img 
        src="/english_adventure_hero.jpg" 
        alt="English Adventure Hero" 
        class="w-full h-56 sm:h-64 object-cover object-center opacity-85 hover:scale-105 transition-transform duration-700 ease-out"
      />
      <div class="absolute bottom-0 left-0 right-0 p-6 sm:p-8 z-20">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-rose-500 text-white mb-3 shadow-md tracking-wide uppercase animate-pulse">
          🎯 Summer Course
        </span>
        <h1 class="text-3xl sm:text-4xl font-extrabold font-display tracking-tight text-white mb-2">
          English Adventure
        </h1>
        <p class="text-slate-200 text-sm sm:text-base font-medium max-w-xl">
          8-week interactive agenda based on <span class="text-amber-300 font-semibold">Interchange Intro</span>. Perfect for learning together!
        </p>
      </div>
    </header>

    <!-- Family Member Selector -->
    <section class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 mb-8">
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-4">
        <div>
          <h2 class="text-lg font-bold text-slate-800">
            Who is studying today?
          </h2>
          <p class="text-xs text-slate-500">Select your profile or add a new one to save your personal progress</p>
        </div>
        
        <button 
          id="btn-open-modal"
          class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold rounded-xl text-indigo-600 bg-indigo-50 hover:bg-indigo-100 transition duration-200 self-start sm:self-auto cursor-pointer"
        >
          <span>Add family member</span>
          <span class="text-lg font-bold">+</span>
        </button>
      </div>

      <!-- Members list -->
      <div class="flex flex-wrap gap-3">
        {users.map(u => {
          const isSelected = u.id === selectedUserId;
          return (
            <a 
              href={`?user_id=${u.id}`}
              class={`flex items-center gap-3 px-4 py-3 rounded-2xl border-2 transition-all duration-300 cursor-pointer ${
                isSelected 
                  ? 'border-indigo-600 bg-indigo-50/50 shadow-sm scale-102 font-bold text-indigo-900' 
                  : 'border-slate-100 bg-slate-50 hover:border-slate-200 hover:bg-slate-100 text-slate-700'
              }`}
            >
              <span class="text-2xl">{u.avatar}</span>
              <span class="text-sm">{u.name}</span>
              {isSelected && (
                <span class="w-2 h-2 rounded-full bg-indigo-600 animate-ping"></span>
              )}
            </a>
          );
        })}
      </div>
    </section>

    <!-- Active User & Progress Stats Header -->
    {selectedUser && (
      <section class="bg-gradient-to-br from-indigo-900 to-slate-900 rounded-2xl p-6 sm:p-8 text-white shadow-lg mb-8 relative overflow-hidden">
        <!-- Decoration Gradients -->
        <div class="absolute right-0 top-0 w-64 h-64 bg-indigo-500/10 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute left-1/3 bottom-0 w-32 h-32 bg-rose-500/10 rounded-full blur-2xl pointer-events-none"></div>

        <div class="flex flex-col sm:flex-row items-center gap-6 z-10 relative">
          <!-- Avatar circle -->
          <div class="w-20 h-20 bg-white/10 backdrop-blur-md rounded-2xl flex items-center justify-center text-4xl shadow-inner border border-white/10 shrink-0">
            {selectedUser.avatar}
          </div>
          
          <div class="flex-grow text-center sm:text-left">
            <span class="text-xs font-semibold text-indigo-300 tracking-wider uppercase">Progress of:</span>
            <h2 class="text-2xl sm:text-3xl font-extrabold text-white mt-0.5">{selectedUser.name}</h2>
            
            <!-- Progress statistics -->
            <div class="mt-4 flex flex-wrap items-center justify-center sm:justify-start gap-x-6 gap-y-2 text-sm text-slate-300">
              <div>
                <strong class="text-white text-base" id="stat-completed">{completedCount}</strong> out of 8 weeks completed
              </div>
              <div class="hidden sm:block text-indigo-700 font-bold">•</div>
              <div id="motivational-message" class="text-indigo-200 italic">
                {percentCompleted === 0 && "Let's start this great adventure! 🚀"}
                {percentCompleted > 0 && percentCompleted <= 30 && "Good start! Every step counts. 🌟"}
                {percentCompleted > 30 && percentCompleted <= 70 && "Great progress! You are doing awesome. 💪"}
                {percentCompleted > 70 && percentCompleted < 100 && "Almost at the finish line! Keep it up! 🎉"}
                {percentCompleted === 100 && "Congratulations! You completed the whole adventure! 🎓🏆"}
              </div>
            </div>
          </div>

          <!-- Circular percentage -->
          <div class="shrink-0 flex flex-col items-center justify-center">
            <div class="relative w-24 h-24 flex items-center justify-center">
              <svg class="w-full h-full transform -rotate-90">
                <circle cx="48" cy="48" r="40" stroke="currentColor" stroke-width="8" class="text-slate-800" fill="transparent" />
                <circle 
                  cx="48" 
                  cy="48" 
                  r="40" 
                  stroke="currentColor" 
                  stroke-width="8" 
                  class="text-rose-500 transition-all duration-500 ease-out" 
                  fill="transparent" 
                  stroke-dasharray={2 * Math.PI * 40}
                  stroke-dashoffset={2 * Math.PI * 40 * (1 - percentCompleted / 100)}
                  id="circle-progress"
                />
              </svg>
              <div class="absolute text-xl font-extrabold text-white font-display">
                <span id="stat-percent">{percentCompleted}</span>%
              </div>
            </div>
          </div>
        </div>

        <!-- Linear Progress Bar wrapper -->
        <div class="mt-6">
          <div class="w-full h-3 bg-slate-950/60 rounded-full overflow-hidden p-0.5 border border-white/5">
            <div 
              class="h-full bg-gradient-to-r from-indigo-500 via-purple-500 to-rose-500 rounded-full transition-all duration-500 ease-out"
              style={{ width: `${percentCompleted}%` }}
              id="bar-progress"
            ></div>
          </div>
        </div>
      </section>
    )}

    <!-- Navigation Tabs -->
    <div class="flex border-b border-slate-200 mb-6 overflow-x-auto whitespace-nowrap scrollbar-none">
      <button 
        data-tab-target="tab-calendario" 
        class="tab-btn active border-b-2 border-indigo-600 px-5 py-3 text-sm font-semibold text-indigo-600 transition cursor-pointer"
      >
        📅 Calendar & Sessions
      </button>
      <button 
        data-tab-target="tab-canciones" 
        class="tab-btn border-b-2 border-transparent px-5 py-3 text-sm font-medium text-slate-500 hover:text-slate-800 transition cursor-pointer"
      >
        🎵 Songs & Videos
      </button>
      <button 
        data-tab-target="tab-progreso" 
        class="tab-btn border-b-2 border-transparent px-5 py-3 text-sm font-medium text-slate-500 hover:text-slate-800 transition cursor-pointer"
      >
        📊 Family Achievements
      </button>
      <button 
        data-tab-target="tab-recursos" 
        class="tab-btn border-b-2 border-transparent px-5 py-3 text-sm font-medium text-slate-500 hover:text-slate-800 transition cursor-pointer"
      >
        📚 Extra Resources
      </button>
    </div>

    <!-- TAB: Calendario -->
    <div id="tab-calendario" class="tab-pane block">
      <div class="grid gap-4">
        {WEEKS.map(w => (
          <WeekCard 
            weekData={w}
            isCompleted={progressMap.get(w.week) || false}
            selectedUserId={selectedUserId}
            sessionProgress={sessionProgressMap.get(w.week) || { 1: false, 2: false, 3: false, 4: false }}
          />
        ))}
      </div>
    </div>

    <!-- TAB: Canciones y Videos -->
    <div id="tab-canciones" class="tab-pane hidden">
      <div class="grid gap-6">
        {WEEKS.filter(w => w.songs.length > 0).map(w => (
          <div class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm">
            <div class="flex items-center gap-2 mb-4">
              <span class="text-xs font-bold px-2 py-0.5 rounded bg-slate-100 text-slate-600">Week {w.week}</span>
              <h3 class="text-base font-bold text-slate-800">{w.unit}: {w.focus.split('(')[0]}</h3>
            </div>

            <div class="grid sm:grid-cols-2 gap-3">
              {w.songs.map(song => (
                <a 
                  href={song.url} 
