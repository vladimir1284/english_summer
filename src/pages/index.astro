    focus: "What time is it? & I ride my bike to school. (Clock time; everyday activities; transportation; family relationships; daily routines; days of the week)",
    songs: [
      { title: "What Time Is It? - Telling Time Song", url: "https://www.youtube.com/watch?v=hqnc_PcvoB0", type: "song" },
      { title: "Time Is Up - Super Simple", url: "https://www.youtube.com/watch?v=2fBkD00JvHY", type: "song" }
    ],
    sessions: [
      { number: 1, sb: "Pages 30-32: Unit 5. Clock time; times of the day. Time expressions: o'clock, A.M., P.M., noon, midnight, morning/afternoon/evening, at 7:00/night/midnight", wb: "Pages 25-26 (exercises 1-3)", extra: "Asking for and telling time" },
      { number: 2, sb: "Pages 33-35: Unit 5. Everyday activities. Present continuous Wh-questions", wb: "Pages 27-30 (exercises 4-7)", extra: "Asking about and describing current activities" },
      { number: 3, sb: "Pages 36-38: Unit 6. Transportation; family relationships. Simple present statements with regular and irregular verbs", wb: "Pages 31-32 (exercises 1-3)", extra: "How people go to work or school; talking about family members" },
      { number: 4, sb: "Pages 39-41: Unit 6. Daily routines; days of the week. Simple present questions; time expressions: early, late, every day, on Sundays/weekends/weekdays. PROGRESS CHECK (Pages 42-43)", wb: "Pages 33-36 (exercises 4-6) + Progress Check", extra: "Describing daily and weekly routines; review Units 5-6" }
    ]
  },
  {
    week: 4,
    unit: "Units 7 & 8",
    focus: "Does it have a view? & Where do you work? (Houses and apartments; rooms & furniture; jobs & workplaces; workday routines)",
    songs: [
      { title: "Hide & Seek Around The House - Super Simple", url: "https://www.youtube.com/watch?v=CnevsHDtJXo", type: "song" },
      { title: "In The Kitchen - Super Simple", url: "https://www.youtube.com/watch?v=2sClBxucyf8", type: "song" }
    ],
    sessions: [
      { number: 1, sb: "Pages 44-46: Unit 7. Houses and apartments; rooms. Simple present short answers; there is, there are", wb: "Pages 37-38 (exercises 1-3)", extra: "Asking about and describing houses and apartments" },
      { number: 2, sb: "Pages 47-49: Unit 7. Furniture. There's no, there isn't a, there are no, there aren't any", wb: "Pages 39-42 (exercises 4-7)", extra: "Talking about the furniture in a room" },
      { number: 3, sb: "Pages 50-52: Unit 8. Jobs and workplaces. Simple present Wh-questions with do and does", wb: "Pages 43-44 (exercises 1-3)", extra: "Asking for and giving information about work; workplaces" },
      { number: 4, sb: "Pages 53-55: Unit 8. Workday routines. Placement of adjectives after be and before nouns. PROGRESS CHECK (Pages 56-57)", wb: "Pages 45-48 (exercises 4-6) + Progress Check", extra: "Giving opinions about jobs; describing workday routines; review Units 7-8" }
    ]
  },
  {
    week: 5,
    unit: "Units 9 & 10",
    focus: "I always eat breakfast. & What sports do you like? (Basic foods; breakfast foods; meals; sports; abilities and talents)",
    songs: [
      { title: "Do You Like Broccoli Ice Cream? - Super Simple", url: "https://www.youtube.com/watch?v=frN3nvhIHUk", type: "song" },
      { title: "What Sports Do You Like? - Song", url: "https://www.youtube.com/watch?v=hqnc_PcvoB0", type: "song" }
    ],
    sessions: [
      { number: 1, sb: "Pages 58-60: Unit 9. Basic foods; breakfast foods; meals. Count and noncount nouns; some and any", wb: "Pages 49-50 (exercises 1-3)", extra: "Talking about food likes and dislikes; healthy and unhealthy foods" },
      { number: 2, sb: "Pages 61-63: Unit 9. Foods you have and need. Adverbs of frequency: always, usually, often, sometimes, hardly ever, never", wb: "Pages 51-54 (exercises 4-7)", extra: "Describing eating habits and meal preferences" },
      { number: 3, sb: "Pages 64-66: Unit 10. Sports; free-time activities. Simple present Wh-questions", wb: "Pages 55-56 (exercises 1-3)", extra: "Asking about free-time activities; sports preferences" },
      { number: 4, sb: "Pages 67-69: Unit 10. Abilities and talents. Can for ability; yes/no and Wh-questions with can. PROGRESS CHECK (Pages 70-71)", wb: "Pages 57-60 (exercises 4-6) + Progress Check", extra: "Asking for and giving information about abilities/talents; review Units 9-10" }
    ]
  },
  {
    week: 6,
    unit: "Units 11 & 12",
    focus: "I'm going to have a party. & How do you feel? (Months & dates; birthdays & holidays; body parts; health problems & advice; medication)",
    songs: [
      { title: "Months of the Year Song - Super Simple", url: "https://www.youtube.com/watch?v=Fe9fvyg250c", type: "song" },
      { title: "The Bath Song (Body Parts) - Super Simple", url: "https://www.youtube.com/watch?v=TDGfI3JvN0Y", type: "song" }
    ],
    sessions: [
      { number: 1, sb: "Pages 72-74: Unit 11. Months and dates; birthdays. The future with be going to: statements and yes/no questions", wb: "Pages 61-62 (exercises 1-3)", extra: "Asking about birthdays; talking about personal plans" },
      { number: 2, sb: "Pages 75-77: Unit 11. Holidays, festivals, special days. Future Wh-questions; future time expressions", wb: "Pages 63-66 (exercises 4-7)", extra: "Talking about plans for the evening, weekend, and special occasions" },
      { number: 3, sb: "Pages 78-80: Unit 12. Parts of the body; health problems. Have + noun; feel + adjective; negative/positive adjectives", wb: "Pages 67-68 (exercises 1-3)", extra: "Describing health problems and physical feelings" },
      { number: 4, sb: "Pages 81-83: Unit 12. Medications. Imperatives. PROGRESS CHECK (Pages 84-85)", wb: "Pages 69-72 (exercises 4-6) + Progress Check", extra: "Talking about medications; giving advice for health problems; review Units 11-12" }
    ]
  },
  {
    week: 7,
    unit: "Units 13 & 14",
    focus: "How do I get there? & I had a good time. (Stores & items; directions; tourist attractions; weekends & vacations; summer activities)",
    songs: [
      { title: "Where Are You Going? - Super Simple", url: "https://www.youtube.com/watch?v=5XEN4vtH4Ic", type: "song" },
      { title: "My Teddy Bear - Super Simple", url: "https://www.youtube.com/watch?v=1GDFa-nEzlg", type: "song" }
    ],
    sessions: [
      { number: 1, sb: "Pages 86-88: Unit 13. Stores and things you can buy there. Prepositions of place: on, on the corner of, across from, next to, between", wb: "Pages 73-74 (exercises 1-3)", extra: "Talking about stores, places, and purchase items" },
      { number: 2, sb: "Pages 89-91: Unit 13. Tourist attractions. Giving directions with imperatives", wb: "Pages 75-78 (exercises 4-7)", extra: "Asking for and giving directions around town" },
      { number: 3, sb: "Pages 92-94: Unit 14. Weekends; chores and fun activities. Simple past statements with regular and irregular verbs", wb: "Pages 79-80 (exercises 1-3)", extra: "Asking for and giving information about weekend activities" },
      { number: 4, sb: "Pages 95-97: Unit 14. Vacations; summer activities. Simple past yes/no questions and short answers. PROGRESS CHECK (Pages 98-99)", wb: "Pages 81-84 (exercises 4-6) + Progress Check", extra: "Talking about vacation and summer activities; review Units 13-14" }
    ]
  },
  {
    week: 8,
