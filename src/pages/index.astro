              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- TAB: Family Achievements -->
    <div id="tab-progreso" class="tab-pane hidden">
      <div class="bg-white rounded-2xl p-6 sm:p-8 border border-slate-100 shadow-sm mb-6">
        <h3 class="text-lg font-bold text-slate-800 mb-6">
          Family Leaderboard
        </h3>
        
        <!-- Compare users progress -->
        <div class="grid gap-6">
          {users.map(u => {
            return (
              <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <span class="text-2xl">{u.avatar}</span>
                    <span class="text-sm font-bold text-slate-700">{u.name}</span>
                    {u.id === selectedUserId && (
                      <span class="text-xs font-medium px-2 py-0.5 rounded bg-indigo-50 text-indigo-600">You</span>
                    )}
                  </div>
                  <span class="text-sm font-bold text-indigo-600" id={`comparison-percent-${u.id}`}>
                    Calculating...
                  </span>
                </div>
                <div class="w-full h-2.5 bg-slate-100 rounded-full overflow-hidden">
                  <div 
                    class="h-full bg-indigo-500 rounded-full transition-all duration-500 ease-out"
                    id={`comparison-bar-${u.id}`}
                    style="width: 0%"
                  ></div>
                </div>
              </div>
            );
          })}
        </div>
      </div>

      <div class="bg-gradient-to-r from-amber-500 to-orange-500 rounded-2xl p-6 text-white shadow-sm flex flex-col sm:flex-row items-center gap-6">
        <span class="text-4xl shrink-0">🏆</span>
        <div>
          <h4 class="text-base font-bold">Summer Challenge!</h4>
          <p class="text-sm text-amber-50 text-balance mt-0.5">
            The first family member to complete all 16 units wins a special surprise! Remember to check your tasks every time you review or sing your songs.
          </p>
        </div>
      </div>
    </div>

    <!-- TAB: Recursos Extra -->
    <div id="tab-recursos" class="tab-pane hidden">
      <div class="grid sm:grid-cols-2 gap-4">
        <div class="p-6 bg-white rounded-2xl border border-slate-100 hover:border-slate-200 transition shadow-sm flex items-start gap-4">
          <span class="text-3xl p-3 rounded-xl bg-green-50 text-green-600 shrink-0">🦉</span>
          <div>
            <h4 class="font-bold text-slate-800 mb-1">Duolingo or Lingokids</h4>
            <p class="text-xs text-slate-500 mb-2">15 minutes daily</p>
            <p class="text-sm text-slate-600 leading-relaxed">
              Ideal for practicing vocabulary in a playful way and staying consistent every day in a fun manner.
            </p>
          </div>
        </div>

        <div class="p-6 bg-white rounded-2xl border border-slate-100 hover:border-slate-200 transition shadow-sm flex items-start gap-4">
          <span class="text-3xl p-3 rounded-xl bg-pink-50 text-pink-600 shrink-0">🐷</span>
          <div>
            <h4 class="font-bold text-slate-800 mb-1">Peppa Pig or Bluey</h4>
            <p class="text-xs text-slate-500 mb-2">Original audio with subtitles</p>
            <p class="text-sm text-slate-600 leading-relaxed">
              Watching short episodes of simple cartoons helps enormously to train the ear and associate sounds with words.
            </p>
          </div>
        </div>

        <div class="p-6 bg-white rounded-2xl border border-slate-100 hover:border-slate-200 transition shadow-sm flex items-start gap-4">
          <span class="text-3xl p-3 rounded-xl bg-indigo-50 text-indigo-600 shrink-0">📘</span>
          <div>
            <h4 class="font-bold text-slate-800 mb-1">Student's Book & Workbook</h4>
            <p class="text-xs text-slate-500 mb-2">Official Interchange Intro</p>
            <p class="text-sm text-slate-600 leading-relaxed">
              Base textbook. Complete the corresponding exercises for each unit to reinforce grammar concepts.
            </p>
          </div>
        </div>

        <div class="p-6 bg-white rounded-2xl border border-slate-100 hover:border-slate-200 transition shadow-sm flex items-start gap-4">
          <span class="text-3xl p-3 rounded-xl bg-amber-50 text-amber-600 shrink-0">🧒</span>
          <div>
            <h4 class="font-bold text-slate-800 mb-1">LearnEnglish Kids</h4>
            <p class="text-xs text-slate-500 mb-2">British Council Portal</p>
            <p class="text-sm text-slate-600 leading-relaxed">
              Website with spelling games, interactive educational videos, and activity sheets ready to print and play.
            </p>
          </div>
        </div>
      </div>
    </div>

  </main>

  <!-- Add Member Modal -->
  <dialog id="modal-add-member" class="rounded-3xl border border-slate-100 bg-white p-6 shadow-2xl backdrop:bg-slate-950/60 backdrop:backdrop-blur-sm max-w-md w-full mx-4">
    <div class="flex items-center justify-between mb-6">
      <h3 class="text-lg font-bold text-slate-800">Add family member</h3>
      <button id="btn-close-modal" class="text-slate-400 hover:text-slate-600 text-2xl font-bold cursor-pointer">×</button>
    </div>

    <form id="form-add-member" class="space-y-4">
      <div>
        <label for="member-name" class="block text-sm font-semibold text-slate-700 mb-1.5">Name</label>
        <input 
          type="text" 
          id="member-name" 
          placeholder="e.g. Sofia, Dad, Mom..." 
          required 
          class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600 text-slate-800"
        />
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-1.5">Choose an emoji</label>
        <div class="grid grid-cols-6 gap-2.5 max-h-40 overflow-y-auto p-1">
          {AVATARS.map((avatar, idx) => (
            <label class="cursor-pointer">
              <input 
                type="radio" 
                name="member-avatar" 
                value={avatar} 
                checked={idx === 0}
                class="sr-only peer" 
              />
              <span class="w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 hover:bg-slate-100 border-2 border-transparent peer-checked:border-indigo-600 peer-checked:bg-indigo-50 text-2xl transition duration-150">
                {avatar}
              </span>
            </label>
          ))}
        </div>
      </div>

      <div id="modal-error" class="text-xs text-rose-600 hidden font-semibold"></div>

      <div class="flex gap-3 pt-2">
        <button 
          type="button" 
          id="btn-cancel-modal"
          class="flex-1 py-3 text-sm font-semibold text-slate-500 bg-slate-50 hover:bg-slate-100 rounded-xl transition cursor-pointer"
        >
          Cancel
        </button>
        <button 
          type="submit" 
          class="flex-1 py-3 text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-700 rounded-xl shadow-md transition cursor-pointer"
        >
          Save
        </button>
      </div>
    </form>
  </dialog>

  <!-- Footnote -->
  <footer class="text-center py-6 text-xs text-slate-400 border-t border-slate-100">
    <p>English Adventure • Made with love for the family 🏕️</p>
  </footer>
</Layout>

<!-- Client-side tab & progress handling script -->
<script is:inline define:vars={{ selectedUserId }}>
  // Manage client-side navigation tabs
  const tabBtns = document.querySelectorAll('.tab-btn');
  const tabPanes = document.querySelectorAll('.tab-pane');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.getAttribute('data-tab-target');
      
      tabBtns.forEach(b => {
        b.classList.remove('active', 'border-indigo-600', 'text-indigo-600');
        b.classList.add('border-transparent', 'text-slate-500');
      });
      tabPanes.forEach(p => p.classList.replace('block', 'hidden'));

      btn.classList.add('active', 'border-indigo-600', 'text-indigo-600');
      btn.classList.remove('border-transparent', 'text-slate-500');
      
      const targetPane = document.getElementById(target);
      if (targetPane) targetPane.classList.replace('hidden', 'block');
    });
  });

  // Modal toggle handlers
  const modal = document.getElementById('modal-add-member');
  const openModalBtn = document.getElementById('btn-open-modal');
  const closeModalBtn = document.getElementById('btn-close-modal');
  const cancelModalBtn = document.getElementById('btn-cancel-modal');
  const addForm = document.getElementById('form-add-member');
  const modalError = document.getElementById('modal-error');

  openModalBtn?.addEventListener('click', () => {
    modalError.classList.add('hidden');
    modalError.textContent = '';
    modal.showModal();
  });

  const closeModal = () => modal.close();
  closeModalBtn?.addEventListener('click', closeModal);
  cancelModalBtn?.addEventListener('click', closeModal);

  // Form submission handler
  addForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    modalError.classList.add('hidden');

    const name = document.getElementById('member-name').value;
    const avatar = document.querySelector('input[name="member-avatar"]:checked')?.value;

    try {
      const res = await fetch('/api/add-user', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, avatar })
      });
      
      const data = await res.json();
      if (res.ok && data.success) {
        // Redirect to selection of new user
        window.location.search = `?user_id=${data.userId}`;
      } else {
        modalError.textContent = data.error || 'An unexpected error occurred';
        modalError.classList.remove('hidden');
      }
    } catch (err) {
      modalError.textContent = 'Error connecting to the server';
      modalError.classList.remove('hidden');
    }
  });

  // Client-side expand/collapse of week cards
  const toggleDetailsBtns = document.querySelectorAll('.toggle-details-btn');
  toggleDetailsBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const card = btn.closest('.week-card');
      const details = card.querySelector('.details-panel');
      const svg = btn.querySelector('svg');
      
      const isHidden = details.classList.contains('hidden');
      if (isHidden) {
        details.classList.remove('hidden');
        svg.classList.add('rotate-180');
      } else {
        details.classList.add('hidden');
        svg.classList.remove('rotate-180');
      }
    });
  });

  // Also support clicking the week-card header to expand details
  const cardHeaders = document.querySelectorAll('.week-card > div:first-child');
  cardHeaders.forEach(header => {
    header.addEventListener('click', (e) => {
      if (e.target.closest('input[type="checkbox"]') || e.target.closest('a') || e.target.closest('button')) {
        return;
      }
      const card = header.closest('.week-card');
      const btn = card.querySelector('.toggle-details-btn');
      if (btn) btn.click();
    });
  });

  // Helper to copy text to clipboard with fallback for non-secure contexts
  async function copyToClipboard(text) {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      try {
        await navigator.clipboard.writeText(text);
        return true;
      } catch (e) {
        console.warn("navigator.clipboard failed, trying fallback", e);
      }
    }
    
    // Fallback using temp textarea
    try {
      const textArea = document.createElement("textarea");
      textArea.value = text;
      textArea.style.top = "0";
      textArea.style.left = "0";
      textArea.style.position = "fixed";
      textArea.style.opacity = "0";
      document.body.appendChild(textArea);
      textArea.focus();
      textArea.select();
      const successful = document.execCommand('copy');
      document.body.removeChild(textArea);
      if (successful) return true;
    } catch (err) {
      console.error("Fallback copy failed", err);
    }
    return false;
  }

  // Progress toggles handling (AJAX) for weeks
  const weekCheckboxes = document.querySelectorAll('.week-checkbox');
  
  weekCheckboxes.forEach(cb => {
    cb.addEventListener('change', async () => {
      const week = parseInt(cb.getAttribute('data-week'), 10);
      const userId = parseInt(cb.getAttribute('data-user-id'), 10);
      const completed = cb.checked;
      
      const card = cb.closest('.week-card');
      const statusBadge = card.querySelector('.status-badge');
      const statusText = card.querySelector('.status-text');

      // Update Card Visuals Instantly
      if (completed) {
        card.classList.add('border-emerald-200', 'bg-emerald-50/10');
        card.classList.remove('border-slate-100');
        if (statusBadge) {
          statusBadge.classList.replace('bg-slate-100', 'bg-emerald-100');
          statusBadge.classList.replace('text-slate-500', 'text-emerald-800');
        }
        if (statusText) statusText.textContent = 'Completed';
      } else {
        card.classList.remove('border-emerald-200', 'bg-emerald-50/10');
        card.classList.add('border-slate-100');
        if (statusBadge) {
          statusBadge.classList.replace('bg-emerald-100', 'bg-slate-100');
          statusBadge.classList.replace('text-emerald-800', 'text-slate-500');
        }
        if (statusText) statusText.textContent = 'Pending';
      }

      // Check/uncheck all sessions for this week in the UI
      const sessionCheckboxes = card.querySelectorAll('.session-checkbox');
      sessionCheckboxes.forEach(scb => {
        scb.checked = completed;
        const row = scb.closest('.session-row');
        if (completed) {
          row.classList.add('border-emerald-100', 'bg-emerald-50/10');
          row.classList.remove('border-slate-100');
          row.querySelectorAll('p').forEach(p => p.classList.add('line-through', 'opacity-60'));
        } else {
          row.classList.remove('border-emerald-100', 'bg-emerald-50/10');
          row.classList.add('border-slate-100');
          row.querySelectorAll('p').forEach(p => p.classList.remove('line-through', 'opacity-60'));
        }
      });

      // Update sub-progress bar in week card
      const subBar = card.querySelector('.week-progress-bar-fill');
      const subBarWrapper = card.querySelector('.week-progress-bar');
      if (subBar && subBarWrapper) {
        subBar.style.width = completed ? '100%' : '0%';
        subBarWrapper.classList.add('hidden'); // Hide the sub-bar when 0% or 100%
      }

      // Update session count badge
      const badgeContainer = card.querySelector('.badge-container');
      const sessionCountBadge = badgeContainer ? badgeContainer.querySelector('span.bg-amber-50') : null;
      if (sessionCountBadge) {
        sessionCountBadge.remove();
      }

      try {
        const res = await fetch('/api/toggle-progress', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId, week, completed })
        });
        
        if (!res.ok) {
          throw new Error('Server error');
        }
        
        updateStats();
      } catch (err) {
        console.error(err);
        // Revert on error without dispatching change event again
        cb.checked = !completed;
        
        if (!completed) {
          card.classList.add('border-emerald-200', 'bg-emerald-50/10');
          card.classList.remove('border-slate-100');
          if (statusBadge) {
            statusBadge.classList.replace('bg-slate-100', 'bg-emerald-100');
            statusBadge.classList.replace('text-slate-500', 'text-emerald-800');
          }
          if (statusText) statusText.textContent = 'Completed';
        } else {
          card.classList.remove('border-emerald-200', 'bg-emerald-50/10');
          card.classList.add('border-slate-100');
          if (statusBadge) {
            statusBadge.classList.replace('bg-emerald-100', 'bg-slate-100');
            statusBadge.classList.replace('text-emerald-800', 'text-slate-500');
          }
          if (statusText) statusText.textContent = 'Pending';
        }

        sessionCheckboxes.forEach(scb => {
          scb.checked = !completed;
          const row = scb.closest('.session-row');
          if (!completed) {
            row.classList.add('border-emerald-100', 'bg-emerald-50/10');
            row.classList.remove('border-slate-100');
            row.querySelectorAll('p').forEach(p => p.classList.add('line-through', 'opacity-60'));
          } else {
            row.classList.remove('border-emerald-100', 'bg-emerald-50/10');
            row.classList.add('border-slate-100');
            row.querySelectorAll('p').forEach(p => p.classList.remove('line-through', 'opacity-60'));
          }
        });

        if (subBar && subBarWrapper) {
          subBar.style.width = !completed ? '100%' : '0%';
          subBarWrapper.classList.add('hidden');
        }

        alert('Error saving progress');
      }
    });
  });

  // Progress toggles handling (AJAX) for individual sessions
  const sessionCheckboxes = document.querySelectorAll('.session-checkbox');
  
  sessionCheckboxes.forEach(scb => {
    scb.addEventListener('change', async () => {
      const week = parseInt(scb.getAttribute('data-week'), 10);
      const sessionNum = parseInt(scb.getAttribute('data-session'), 10);
      const userId = parseInt(scb.getAttribute('data-user-id'), 10);
      const completed = scb.checked;
      
      const row = scb.closest('.session-row');
      
      // Update session row visuals instantly
      if (completed) {
        row.classList.add('border-emerald-100', 'bg-emerald-50/10');
        row.classList.remove('border-slate-100');
        row.querySelectorAll('p').forEach(p => p.classList.add('line-through', 'opacity-60'));
      } else {
        row.classList.remove('border-emerald-100', 'bg-emerald-50/10');
        row.classList.add('border-slate-100');
        row.querySelectorAll('p').forEach(p => p.classList.remove('line-through', 'opacity-60'));
      }

      try {
        const res = await fetch('/api/toggle-session', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId, week, sessionNum, completed })
        });
        
        if (!res.ok) {
          throw new Error('Server error');
        }
        
        const data = await res.json();
        
        // Update the week checkbox based on whether all sessions are now completed
        const card = scb.closest('.week-card');
        const weekCb = card.querySelector('.week-checkbox');
        weekCb.checked = data.weekCompleted;
        
        // Update week card visuals
        const statusBadge = card.querySelector('.status-badge');
        const statusText = card.querySelector('.status-text');
        
        if (data.weekCompleted) {
          card.classList.add('border-emerald-200', 'bg-emerald-50/10');
          card.classList.remove('border-slate-100');
          if (statusBadge) {
            statusBadge.classList.replace('bg-slate-100', 'bg-emerald-100');
            statusBadge.classList.replace('text-slate-500', 'text-emerald-800');
          }
          if (statusText) statusText.textContent = 'Completed';
        } else {
          card.classList.remove('border-emerald-200', 'bg-emerald-50/10');
          card.classList.add('border-slate-100');
          if (statusBadge) {
            statusBadge.classList.replace('bg-emerald-100', 'bg-slate-100');
            statusBadge.classList.replace('text-emerald-800', 'text-slate-500');
          }
          if (statusText) statusText.textContent = 'Pending';
        }
        
        // Update sub-progress bar in week card
        const subBar = card.querySelector('.week-progress-bar-fill');
        const subBarWrapper = card.querySelector('.week-progress-bar');
        if (subBar && subBarWrapper) {
          const percent = Math.round((data.completedSessionsCount / 4) * 100);
          subBar.style.width = `${percent}%`;
          
          if (percent > 0 && percent < 100) {
            subBarWrapper.classList.remove('hidden');
          } else {
            subBarWrapper.classList.add('hidden');
          }
        }
        
        // Update session count badge
        const badgeContainer = card.querySelector('.badge-container');
        if (badgeContainer) {
          let sessionCountBadge = badgeContainer.querySelector('span.bg-amber-50');
          if (data.completedSessionsCount > 0 && data.completedSessionsCount < 4) {
            if (!sessionCountBadge) {
              sessionCountBadge = document.createElement('span');
              sessionCountBadge.className = 'inline-flex px-2 py-0.5 rounded-md text-xs font-semibold bg-amber-50 text-amber-700 border border-amber-200';
              badgeContainer.appendChild(sessionCountBadge);
            }
            sessionCountBadge.textContent = `${data.completedSessionsCount}/4 Sessions`;
          } else {
            if (sessionCountBadge) {
              sessionCountBadge.remove();
            }
          }
        }
        
        updateStats();
      } catch (err) {
        console.error(err);
        // Revert checkbox state on error
        scb.checked = !completed;
        if (!completed) {
          row.classList.add('border-emerald-100', 'bg-emerald-50/10');
          row.classList.remove('border-slate-100');
          row.querySelectorAll('p').forEach(p => p.classList.add('line-through', 'opacity-60'));
        } else {
          row.classList.remove('border-emerald-100', 'bg-emerald-50/10');
          row.classList.add('border-slate-100');
          row.querySelectorAll('p').forEach(p => p.classList.remove('line-through', 'opacity-60'));
        }
        alert('Error saving session progress');
      }
    });
  });

  // AI Prompt Copying and Toggling via Event Delegation
  document.addEventListener('click', async (e) => {
    const copyBtn = e.target.closest('.copy-prompt-btn');
    if (copyBtn) {
      const promptText = copyBtn.getAttribute('data-prompt');
      const copied = await copyToClipboard(promptText);
      
      if (copied) {
        // Show temporary copied state by replacing SVG with a checkmark path
        const svg = copyBtn.querySelector('svg');
        let originalSVG = "";
        if (svg) {
          originalSVG = svg.innerHTML;
          svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />';
        }
        
        const span = copyBtn.querySelector('span');
        const originalText = span ? span.textContent : null;
        if (span) span.textContent = '¡Copiado!';
        
        copyBtn.classList.add('bg-emerald-50', 'text-emerald-700', 'border-emerald-200');
        copyBtn.classList.remove('bg-indigo-50', 'text-indigo-700', 'border-indigo-100');
        
        setTimeout(() => {
          if (svg) svg.innerHTML = originalSVG;
          if (span) span.textContent = originalText;
          copyBtn.classList.remove('bg-emerald-50', 'text-emerald-700', 'border-emerald-200');
          copyBtn.classList.add('bg-indigo-50', 'text-indigo-700', 'border-indigo-100');
        }, 2000);
      } else {
        alert('No se pudo copiar el prompt automáticamente.');
      }
      return;
    }

    const toggleBtn = e.target.closest('.toggle-prompt-view-btn');
    if (toggleBtn) {
      const row = toggleBtn.closest('.session-row');
      const previewBox = row.querySelector('.prompt-preview-box');
      if (previewBox) {
        previewBox.classList.toggle('hidden');
        const isHidden = previewBox.classList.contains('hidden');
        if (isHidden) {
          toggleBtn.classList.remove('text-indigo-600', 'bg-indigo-50');
          toggleBtn.classList.add('text-slate-400');
        } else {
          toggleBtn.classList.add('text-indigo-600', 'bg-indigo-50');
          toggleBtn.classList.remove('text-slate-400');
        }
      }
      return;
    }
  });

  function updateStats() {
    const total = 8;
    const checked = Array.from(weekCheckboxes).filter(cb => cb.checked).length;
    const percent = Math.round((checked / total) * 100);

    // Update statistics numbers
    const statCompleted = document.getElementById('stat-completed');
    if (statCompleted) statCompleted.textContent = checked;

    const statPercent = document.getElementById('stat-percent');
    if (statPercent) statPercent.textContent = percent;

    // Update linear bar
    const barProgress = document.getElementById('bar-progress');
    if (barProgress) barProgress.style.width = `${percent}%`;

    // Update circular progress circle offset
    const circle = document.getElementById('circle-progress');
    if (circle) {
      const radius = 40;
      const circumference = 2 * Math.PI * radius;
      const offset = circumference * (1 - percent / 100);
      circle.style.strokeDashoffset = offset;
    }

    // Update motivational text
    const messageEl = document.getElementById('motivational-message');
    if (messageEl) {
      let msg = "";
      if (percent === 0) msg = "Let's start this great adventure! 🚀";
      else if (percent <= 30) msg = "Good start! Every step counts. 🌟";
      else if (percent <= 70) msg = "Great progress! You are doing awesome. 💪";
      else if (percent < 100) msg = "Almost at the finish line! Keep it up! 🎉";
      else msg = "Congratulations! You completed the whole adventure! 🎓🏆";
      messageEl.textContent = msg;
    }

    // Update comparative table stats
    const compBar = document.getElementById(`comparison-bar-${selectedUserId}`);
    if (compBar) compBar.style.width = `${percent}%`;

    const compPercent = document.getElementById(`comparison-percent-${selectedUserId}`);
    if (compPercent) compPercent.textContent = `${percent}% (${checked}/8)`;
  }

  // Load comparative stats for all users dynamically on page load
  async function loadAllProgressStats() {
    try {
      const usersEl = document.querySelectorAll('[id^="comparison-bar-"]');
      for (const el of usersEl) {
        const id = el.id.replace('comparison-bar-', '');
        
        // Fetch progress for this specific user
        const res = await fetch(`/api/user-progress-summary?user_id=${id}`);
        if (res.ok) {
          const data = await res.json();
          const percent = Math.round((data.completedCount / 8) * 100);
          
          el.style.width = `${percent}%`;
          const textEl = document.getElementById(`comparison-percent-${id}`);
          if (textEl) {
            textEl.textContent = `${percent}% (${data.completedCount}/8)`;
          }
        }
      }
    } catch (e) {
      console.error('Failed to load comparison stats', e);
    }
  }

  // Run on mount
  window.addEventListener('DOMContentLoaded', () => {
    updateStats();
    loadAllProgressStats();
  });
</script>
