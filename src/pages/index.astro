---
import Layout from '../layouts/Layout.astro';
import { getDB } from '../utils/db';
import WeekCard from '../components/WeekCard.astro';

// Define TS Interfaces for DB types
interface UserRow {
  id: number;
  name: string;
  avatar: string;
}

interface ProgressRow {
  user_id: number;
  week: number;
  completed: number;
}

interface SessionProgressRow {
  user_id: number;
  week: number;
  session_num: number;
  completed: number;
}

// Get database
const db = await getDB(Astro.locals);

// Query all users
let users: UserRow[] = [];
try {
  const usersResult = await db.prepare('SELECT * FROM users ORDER BY id ASC').all<UserRow>();
  users = usersResult.results || [];
} catch (e: any) {
  console.log("[DEBUG ERROR] Database query failed:", e.message, e.stack);
}

// Select active user
const url = new URL(Astro.request.url);
const userIdParam = url.searchParams.get('user_id');
let selectedUserId = userIdParam ? parseInt(userIdParam, 10) : (users[0]?.id || 1);

let selectedUser = users.find(u => u.id === selectedUserId);
if (!selectedUser && users.length > 0) {
  selectedUser = users[0];
  selectedUserId = users[0].id;
}

// Query progress for selected user
let progressRows: ProgressRow[] = [];
if (selectedUser) {
  try {
    const progressResult = await db.prepare('SELECT * FROM progress WHERE user_id = ? ORDER BY week ASC')
      .bind(selectedUserId)
      .all<ProgressRow>();
    progressRows = progressResult.results || [];
  } catch (e: any) {
    console.log("[DEBUG ERROR] Failed to query progress:", e.message, e.stack);
  }
}

// Build progress map
const progressMap = new Map<number, boolean>();
for (let i = 1; i <= 8; i++) {
  progressMap.set(i, false);
}
progressRows.forEach(row => {
  progressMap.set(row.week, row.completed === 1);
});

// Query session progress for selected user
let sessionProgressRows: SessionProgressRow[] = [];
if (selectedUser) {
  try {
    const sessionProgressResult = await db.prepare('SELECT * FROM session_progress WHERE user_id = ?')
      .bind(selectedUserId)
      .all<SessionProgressRow>();
    sessionProgressRows = sessionProgressResult.results || [];
  } catch (e: any) {
    console.log("[DEBUG ERROR] Failed to query session progress:", e.message, e.stack);
  }
}

// Build session progress map: week (1..8) -> session_num (1..4) -> completed (boolean)
const sessionProgressMap = new Map<number, Record<number, boolean>>();
for (let i = 1; i <= 8; i++) {
  sessionProgressMap.set(i, { 1: false, 2: false, 3: false, 4: false });
}
sessionProgressRows.forEach(row => {
  const wMap = sessionProgressMap.get(row.week);
  if (wMap) {
    wMap[row.session_num] = row.completed === 1;
  }
});

// Calculate statistics
const totalWeeks = 8;
const completedCount = Array.from(progressMap.values()).filter(Boolean).length;
const percentCompleted = Math.round((completedCount / totalWeeks) * 100);

// Static Weeks Data with Sessions
interface SongVideo {
  title: string;
  url: string;
  type: 'song' | 'video';
}

interface SessionData {
  number: number;
  sb: string;
  wb: string;
  extra: string;
}

interface WeekData {
  week: number;
  unit: string;
  focus: string;
  songs: SongVideo[];
  sessions: SessionData[];
}

const WEEKS: WeekData[] = [
  {
    week: 1,
    unit: "Units 1 & 2",
    focus: "What's your name? & Where are my keys? (Greetings; spelling; numbers 0-10; phone numbers; email; possessions; classroom/personal items; locations in a room)",
    songs: [
      { title: "Hello Hello! - Super Simple", url: "https://www.youtube.com/watch?v=fN1Cyr0ZK9M", type: "song" },
      { title: "Hello! - Super Simple", url: "https://www.youtube.com/watch?v=tVlcKp3bWH8", type: "song" },
      { title: "ABC Song - Super Simple", url: "https://www.youtube.com/watch?v=5XEN4vtH4Ic", type: "song" },
      { title: "Where is Thumbkin? - Super Simple", url: "https://www.youtube.com/watch?v=y3nBnyg15wA", type: "song" },
      { title: "Clean Up Song - Super Simple", url: "https://www.youtube.com/watch?v=1GDFa-nEzlg", type: "song" }
    ],
    sessions: [
      { number: 1, sb: "Pages 2-4: Unit 1. Conversation, Snapshot (names and nicknames), Grammar Focus (Possessive adjectives my, your, his, her; the verb be)", wb: "Pages 1-2 (exercises 1-4)", extra: "Greetings and leave-takings; introducing yourself and friends" },
      { number: 2, sb: "Pages 5-7: Unit 1. Alphabet; numbers 0-10; phone numbers; and email addresses. Affirmative statements and contractions", wb: "Pages 3-6 (exercises 5-10)", extra: "Saying hello and good-bye; asking for names and phone numbers" },
      { number: 3, sb: "Pages 8-10: Unit 2. Snapshot (classroom objects), Conversation, Grammar Focus (Articles a, an, the; this/these, it/they; plurals)", wb: "Pages 7-9 (exercises 1-3)", extra: "Naming possessions, classroom objects, and personal items" },
      { number: 4, sb: "Pages 11-13: Unit 2. Prepositions of place (in, in front of, behind, on, next to, under); yes/no and where questions with be. PROGRESS CHECK (Pages 14-15)", wb: "Pages 10-12 (exercises 4-6) + Progress Check", extra: "Asking for and giving locations of objects; review Units 1-2" }
    ]
  },
  {
    week: 2,
    unit: "Units 3 & 4",
    focus: "Where are you from? & Is this coat yours? (Cities and countries; adjectives of personality & appearance; numbers 11-103; ages; clothing & colors; weather & seasons)",
    songs: [
      { title: "Hello Around the World", url: "https://www.youtube.com/watch?v=fN1Cyr0ZK9M", type: "song" },
      { title: "This Is The Way We Get Dressed - Super Simple", url: "https://www.youtube.com/watch?v=1GDFa-nEzlg", type: "song" }
    ],
    sessions: [
      { number: 1, sb: "Pages 16-18: Unit 3. Cities and countries; nationalities. The verb be: affirmative/negative statements, yes/no questions, short answers", wb: "Pages 13-14 (exercises 1-3)", extra: "Talking about cities and countries; place of origin; nationality" },
      { number: 2, sb: "Pages 19-21: Unit 3. Adjectives of personality and appearance; numbers 11-103 and ages. Wh-questions with be", wb: "Pages 15-18 (exercises 4-7)", extra: "First language and age; describing people's personality/appearance" },
      { number: 3, sb: "Pages 22-24: Unit 4. Clothing; colors. Possessives: adjectives our/their, pronouns, names, whose. Placement of adjectives before nouns", wb: "Pages 19-20 (exercises 1-3)", extra: "Asking about and describing clothing and colors; finding owners" },
      { number: 4, sb: "Pages 25-27: Unit 4. Weather and seasons. Present continuous statements and questions; conjunctions and, but, so. PROGRESS CHECK (Pages 28-29)", wb: "Pages 21-24 (exercises 4-6) + Progress Check", extra: "Talking about the weather and seasons; review Units 3-4" }
    ]
  },
  {
