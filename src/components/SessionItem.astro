---
interface Props {
  week: number;
  sessionNum: number;
  sb: string;
  wb: string;
  extra: string;
  isCompleted: boolean;
  userId: number;
}

const { week, sessionNum, sb, wb, extra, isCompleted, userId } = Astro.props;
---

<div 
  class={`session-row flex flex-col md:flex-row md:items-center gap-4 p-4 rounded-xl border transition-all duration-300 ${
    isCompleted 
      ? 'border-emerald-100 bg-emerald-50/10' 
      : 'border-slate-100 hover:border-slate-200 bg-slate-50/20'
  }`}
  data-week={week}
  data-session={sessionNum}
>
  <!-- Left Column: Checkbox + Session Title -->
  <div class="flex items-center gap-3 shrink-0 md:w-36">
    <input 
      type="checkbox"
      class="session-checkbox w-5 h-5 border-2 rounded cursor-pointer transition-all border-slate-300 text-emerald-600 focus:ring-emerald-500 focus:ring-offset-1 checked:border-emerald-600"
      checked={isCompleted}
      data-week={week}
      data-session={sessionNum}
      data-user-id={userId}
    />
    <span class={`text-sm font-bold tracking-wide uppercase ${isCompleted ? 'text-emerald-700' : 'text-slate-600'}`}>
      Session {sessionNum}
    </span>
  </div>

  <!-- Middle/Right Column: Main Contents -->
  <div class="flex-grow grid grid-cols-1 md:grid-cols-3 gap-3 text-sm">
    <!-- Student's Book -->
    {sb && sb !== '—' ? (
      <div class="flex items-start gap-2">
        <span class="text-indigo-500 shrink-0 text-base" title="Student's Book">📖</span>
        <div>
          <span class="font-semibold text-slate-700 block text-xs tracking-wider uppercase mb-0.5">Student's Book</span>
          <p class={`text-slate-600 leading-relaxed ${isCompleted ? 'line-through opacity-60' : ''}`}>{sb}</p>
        </div>
      </div>
    ) : (
      <div class="hidden md:block opacity-40 text-xs italic text-slate-400 self-center">No SB assigned</div>
    )}

    <!-- Workbook -->
    {wb && wb !== '—' ? (
      <div class="flex items-start gap-2">
        <span class="text-purple-500 shrink-0 text-base" title="Workbook">✍️</span>
        <div>
          <span class="font-semibold text-slate-700 block text-xs tracking-wider uppercase mb-0.5">Workbook</span>
          <p class={`text-slate-600 leading-relaxed ${isCompleted ? 'line-through opacity-60' : ''}`}>{wb}</p>
        </div>
      </div>
    ) : (
      <div class="hidden md:block opacity-40 text-xs italic text-slate-400 self-center">No WB assigned</div>
    )}

    <!-- Actividades Extra -->
    {extra && extra !== '—' ? (
      <div class="flex items-start gap-2">
        <span class="text-amber-500 shrink-0 text-base" title="Extra activities">🌟</span>
        <div>
          <span class="font-semibold text-slate-700 block text-xs tracking-wider uppercase mb-0.5">Extra Activities</span>
          <p class={`text-slate-600 leading-relaxed ${isCompleted ? 'line-through opacity-60' : ''}`}>{extra}</p>
        </div>
      </div>
    ) : (
      <div class="hidden md:block opacity-40 text-xs italic text-slate-400 self-center">No extra activity</div>
    )}
  </div>
</div>
